AI_PROVIDER=fallback

# Options:
# fallback = no external AI, always returns a template diagram
# gemini = free hosted Gemini API tier, requires GEMINI_API_KEY
# ollama = fully local model, requires Ollama running on your computer
# openai = paid OpenAI API, requires OPENAI_API_KEY

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

PORT=5001
CLIENT_ORIGIN=http://localhost:5173

# ==========================================
# MongoDB Atlas & Authentication Config
# ==========================================
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/ai-whiteboard?retryWrites=true&w=majority
JWT_SECRET=super_secret_cyber_security_key_ai_workspace

# ==========================================
# Real SMTP Email Setup (e.g. Gmail) to send reset passwords:
# ==========================================
# For Gmail SMTP configuration:
# 1. Open your Google Account console -> Security tab.
# 2. Under "How you sign in to Google", ensure "2-Step Verification" is turned ON.
# 3. Search for "App Passwords" or go directly to: https://myaccount.google.com/apppasswords
# 4. Create a new app password named "AI Workspace" and copy the generated 16-character code.
# 5. Paste the code into EMAIL_PASS below, and enter your Gmail address in EMAIL_USER:
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
